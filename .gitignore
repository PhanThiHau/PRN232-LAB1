## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Release]/
[Re]leasePublic/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Log]s/
[Te]mp/

# Visual Studio 2015/2017 cache directory
.vs/
# Uncomment if multiple varieties of VS are installed in the same folder
#  .vs.MS-xxxx/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Cc]oformance/

# NUnit
*.visualstate
*.suo.xslt

# Build Results of Database Project
*.dbmdl
*.jfm

# CoreCLR dumps
dump_*.dmp

# VS Code
.vscode/

# Rider
.idea/
*.sln.iml

# UserSecretId
appsettings.local.json
